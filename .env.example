# Vite exposes every VITE_* value to browser code. Do not put production
# secrets, private salts, or privileged credentials in this file.

# App runtime: local KERIA defaults are used when these are omitted.
VITE_KERIA_ADMIN_URL=http://127.0.0.1:3901
VITE_KERIA_ROUTER_URL=http://127.0.0.1:3902
VITE_KERIA_BOOT_URL=http://127.0.0.1:3903
VITE_KERIA_CONNECTION_LABEL=Local KERIA

# Optional second connection choice for the browser connect dialog.
# Set both URLs together or leave both blank.
# VITE_CLOUD_KERIA_ADMIN_URL=https://keria.example.test
# VITE_CLOUD_KERIA_BOOT_URL=https://keria.example.test/boot
# VITE_CLOUD_KERIA_CONNECTION_LABEL=Cloud KERIA

# Operation waiting policy.
VITE_OPERATION_TIMEOUT_MS=30000
VITE_OPERATION_MIN_SLEEP_MS=1000
VITE_OPERATION_MAX_SLEEP_MS=5000

# Local demo witnesses.
VITE_WITNESS_AIDS=BBilc4-L3tFUnfM_wJr4S4OJanAv_VmF_dJNN6vkf2Ha,BLskRTInXnMxWaGqcpSyMgo0nYbalW99cGZESrz3zapM,BIKKuvBwpmDVA4Ds-EpL5bt9OqPzWPja2LigFYZN2YfX
VITE_WITNESS_TOAD=2

# Demo role labels and optional scripted-demo passcodes.
VITE_ISSUER_ALIAS=issuer
# VITE_ISSUER_PASSCODE=
VITE_HOLDER_ALIAS=holder
# VITE_HOLDER_PASSCODE=
VITE_VERIFIER_ALIAS=verifier
# VITE_VERIFIER_PASSCODE=

# SEDI voter credential schema config.
# Legacy aliases VITE_CREDENTIAL_SCHEMA_SAID and
# VITE_CREDENTIAL_SCHEMA_OOBI_URL are still accepted.
VITE_SEDI_VOTER_ID_SCHEMA_SAID=EKfZLPrEjUG31Z7PJgftOVkvoPkLtHBWM2TVQ0f8uyjo
VITE_SEDI_VOTER_ID_SCHEMA_OOBI_URL=http://127.0.0.1:7723/oobi/EKfZLPrEjUG31Z7PJgftOVkvoPkLtHBWM2TVQ0f8uyjo

# Sally-style verifier demo config.
VITE_VERIFIER_DIRECT_URL=http://127.0.0.1:9723
VITE_VERIFIER_DASHBOARD_URL=http://127.0.0.1:9923
# VITE_VERIFIER_OOBI_URL=
